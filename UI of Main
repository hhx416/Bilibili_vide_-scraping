os.makedirs(OUTPUT_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)
os.makedirs(SCRIPTS_DIR, exist_ok=True)


def find_script_by_hash(script_key):
    ref_hash = REFERENCE_HASHES.get(script_key)
    if not ref_hash or not os.path.isdir(SCRIPTS_DIR):
        return None
    for fname in os.listdir(SCRIPTS_DIR):
        fpath = os.path.join(SCRIPTS_DIR, fname)
        if not os.path.isfile(fpath):
            continue
        try:
            with open(fpath, 'rb') as f:
                h = hashlib.sha256(f.read()).hexdigest()
            if h.lower() == ref_hash.lower():
                return fpath
        except Exception:
            continue
    return None


def get_script_hash(fpath):
    try:
        with open(fpath, 'rb') as f:
            return hashlib.sha256(f.read()).hexdigest()
    except Exception:
        return None


SCRIPTS = {}


def init_scripts():
    global SCRIPTS
    SCRIPTS = {}
    for key in SCRIPT_NAMES:
        path = find_script_by_hash(key)
        if path:
            SCRIPTS[key] = path


init_scripts()


