    "bsp":  "番剧下载",
}

REFERENCE_HASHES = {
    "bspv": "546ec42f7c130edb01ecc90e50f029535b8e7ad943fa2f1c77cc0133032d1724",
    "bsps": "11d2e5c91cebd3e687b3336ff3a70bfed43835c1781f92923cf7e03e8ef4a26a",
