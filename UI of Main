    def _recheck_scripts(self):
        self._check_scripts()
        self._update_script_info_display()

    def _update_script_info_display(self):
        for key, name in SCRIPT_NAMES.items():
            status_label = self.script_status_labels.get(key)
            path_entry = self.script_path_entries.get(key)
            hash_label = self.script_hash_labels.get(key)
            if not status_label or not path_entry or not hash_label:
                continue

            path = SCRIPTS.get(key)
            if path:
                status_label.config(text="✓ 验证通过", fg="green")
                path_entry.configure(state='normal')
                path_entry.delete(0, tk.END)
                path_entry.insert(0, path)
                path_entry.configure(state='readonly')
                h = get_script_hash(path)
                hash_label.config(text=h[:16] + "..." if h else "-")
            else:
                status_label.config(text="✗ 未找到", fg="red")
                path_entry.configure(state='normal')
                path_entry.delete(0, tk.END)
                path_entry.insert(0, "(未找到匹配文件)")
                path_entry.configure(state='readonly')
                ref = REFERENCE_HASHES.get(key, "")
                hash_label.config(text=f"期望: {ref[:16]}...")

    def _on_task_type_change(self):
        t = self.task_type_var.get()
        if t == "bv":
            self.task_param1_label.config(text="BV号：")
            self.task_param2_label.config(text="画质ID：")
            self.task_param2_entry.config(state='normal')
        elif t == "search":
            self.task_param1_label.config(text="关键词：")
            self.task_param2_label.config(text="数量：")
            self.task_param2_entry.config(state='normal')
            self.task_param2_entry.delete(0, tk.END)
            self.task_param2_entry.insert(0, "5")
        elif t == "pgc":
            self.task_param1_label.config(text="番剧URL：")
            self.task_param2_label.config(text="(自动选画质)")
            self.task_param2_entry.config(state='disabled')

    def _add_batch_task(self):
        t = self.task_type_var.get()
        param1 = self.task_param1_entry.get().strip()
        param2 = self.task_param2_entry.get().strip()

        if not param1:
            messagebox.showwarning("提示", "请输入参数")
            return

        if t == "bv":
            desc = f"单视频: {param1}"
            if param2:
                desc += f" (画质:{param2})"
            else:
                desc += " (最高画质)"
            task = {"type": "bv", "bv": param1, "quality": param2, "desc": desc}
        elif t == "search":
            count = int(param2) if param2.isdigit() else 5
            desc = f"搜索下载: {param1} ({count}个)"
            task = {"type": "search", "keyword": param1, "count": count, "desc": desc}
        elif t == "pgc":
            desc = f"番剧下载: {param1}"
            task = {"type": "pgc", "url": param1, "desc": desc}
        else:
            return

        self.batch_tasks.append(task)
        self.task_listbox.insert(tk.END, f"{len(self.batch_tasks)}. {task['desc']}")
        self._update_task_count()
        self.task_param1_entry.delete(0, tk.END)
        if t == "bv":
            self.task_param2_entry.delete(0, tk.END)

    def _remove_selected_task(self):
        selected = self.task_listbox.curselection()
        if not selected:
            return
        idx = selected[0]
        del self.batch_tasks[idx]
        self.task_listbox.delete(idx)
        self._refresh_task_listbox()

    def _clear_batch_tasks(self):
        self.batch_tasks = []
        self.task_listbox.delete(0, tk.END)
        self._update_task_count()

    def _refresh_task_listbox(self):
        self.task_listbox.delete(0, tk.END)
        for i, t in enumerate(self.batch_tasks, 1):
            self.task_listbox.insert(tk.END, f"{i}. {t['desc']}")
        self._update_task_count()

    def _update_task_count(self):
        self.task_count_var.set(f"共 {len(self.batch_tasks)} 个任务")

    def _load_cookie(self):
        if os.path.exists(COOKIE_FILE):
            with open(COOKIE_FILE, "r", encoding="utf-8") as f:
                return f.read().strip()
        return ""

    def _save_cookie(self):
        cookie_str = self.cookie_text.get('1.0', tk.END).strip()
        if cookie_str:
            with open(COOKIE_FILE, "w", encoding="utf-8") as f:
                f.write(cookie_str)
            self.cookie = cookie_str
            self._update_cookie_status()
            messagebox.showinfo("成功", f"Cookie 已保存 ({len(cookie_str)} 字符)")
        else:
            messagebox.showwarning("提示", "Cookie 不能为空")

    def _load_cookie_to_text(self):
        cookie = self._load_cookie()
        self.cookie_text.delete('1.0', tk.END)
        if cookie:
            self.cookie_text.insert('1.0', cookie)

    def _clear_cookie(self):
        self.cookie_text.delete('1.0', tk.END)

    def _update_cookie_status(self):
        if self.cookie:
            self.cookie_status_label.config(text=f"Cookie: 已设置 ({len(self.cookie)} 字符)", foreground='green')
        else:
            self.cookie_status_label.config(text="Cookie: 未设置", foreground='red')

    def _clear_log(self):
        self.log_text.configure(state='normal')
        self.log_text.delete('1.0', tk.END)
        self.log_text.configure(state='disabled')

    def _open_output_dir(self):
        if os.path.exists(OUTPUT_DIR):
            os.startfile(OUTPUT_DIR)

    def _open_log_dir(self):
        if os.path.exists(LOG_DIR):
            os.startfile(LOG_DIR)

    def _open_path(self, path):
        try:
            if os.path.exists(path):
                if os.path.isdir(path):
                    os.startfile(path)
                else:
                    os.startfile(os.path.dirname(path))
        except Exception as e:
            messagebox.showerror("错误", f"无法打开路径: {e}")

    def _log(self, msg):
        self.log_queue.put(('line', msg))

    def _log_cr(self, text):
        self.log_queue.put(('cr', text))

    def _process_log_queue(self):
        try:
            while True:
                msg_type, msg = self.log_queue.get_nowait()
                self.log_text.configure(state='normal')
                if msg_type == 'line':
                    self.log_text.insert(tk.END, msg + '\n')
                elif msg_type == 'cr':
                    last_newline = self.log_text.index('end-1c linestart')
                    self.log_text.delete(last_newline, 'end-1c')
                    self.log_text.insert(tk.END, msg)
                self.log_text.see(tk.END)
                self.log_text.configure(state='disabled')
        except queue.Empty:
            pass
        self.root.after(50, self._process_log_queue)

    def _check_scripts(self):
        init_scripts()
        self.script_status = {}
        missing = []
        for key, name in SCRIPT_NAMES.items():
            path = SCRIPTS.get(key)
            if path:
                self.script_status[key] = ("ok", path)
            else:
                self.script_status[key] = ("missing", None)
                missing.append(name)
        self._refresh_script_buttons()
        if hasattr(self, 'script_status_labels'):
            self._update_script_info_display()
        if missing:
            msg = "以下脚本未在 scripts/ 目录中找到（按内容哈希验证）：\n\n"
            for m in missing:
                msg += f"  • {m}\n"
            msg += f"\n脚本目录: {SCRIPTS_DIR}\n\n请将正确的脚本文件放入 scripts 目录后重新启动。"
            messagebox.showwarning("脚本验证失败", msg)

    def _refresh_script_buttons(self):
        single_ok = "bspv" in SCRIPTS
        search_ok = "bsps" in SCRIPTS
        pgc_ok = "bsp" in SCRIPTS
        self.download_single_btn.config(state='normal' if single_ok and not self.is_running else 'disabled')
        self.download_search_btn.config(state='normal' if search_ok and not self.is_running else 'disabled')
        self.download_pgc_btn.config(state='normal' if pgc_ok and not self.is_running else 'disabled')
        batch_ok = single_ok or search_ok or pgc_ok
        self.run_batch_btn.config(state='normal' if batch_ok and not self.is_running else 'disabled')

    def _set_running(self, running):
        self.is_running = running
        self._refresh_script_buttons()
        if running:
            self.status_var.set("运行中...")
        else:
            self.status_var.set("就绪")

    def _run_script_thread(self, script_path, inputs, task_name):
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        log_file = os.path.join(LOG_DIR, f"{timestamp}_{task_name}_runner.log")

        all_inputs = list(inputs) + [""]
        input_text = "\n".join(str(x) for x in all_inputs) + "\n"
        input_bytes = input_text.encode("utf-8")

        env = os.environ.copy()
        env["PYTHONIOENCODING"] = "utf-8"
        env["PYTHONUTF8"] = "1"
        env["PYTHONUNBUFFERED"] = "1"
        env["BILI_BASE_DIR"] = BASE_DIR

        try:
            proc = subprocess.Popen(
                [sys.executable, "-u", script_path],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                cwd=BASE_DIR,
                env=env,
                bufsize=0,
            )

            self._log(f"\n{'='*60}")
            self._log(f"  开始执行: {task_name}")
            self._log(f"  脚本: {os.path.basename(script_path)}")
            self._log(f"{'='*60}\n")

            proc.stdin.write(input_bytes)
            proc.stdin.flush()
            proc.stdin.close()

            buffer = ""
            while True:
                chunk = proc.stdout.read(4096)
                if not chunk:
                    break
                try:
                    decoded = chunk.decode('utf-8', errors='replace')
                except Exception:
                    decoded = str(chunk)
                buffer += decoded
                while '\n' in buffer or '\r' in buffer:
                    if '\r' in buffer and ('\n' not in buffer or buffer.index('\r') < buffer.index('\n')):
                        cr_idx = buffer.index('\r')
                        line = buffer[:cr_idx]
                        buffer = buffer[cr_idx + 1:]
                        if line:
                            self._log_cr(line)
                    elif '\n' in buffer:
                        nl_idx = buffer.index('\n')
                        line = buffer[:nl_idx]
                        buffer = buffer[nl_idx + 1:]
                        if line.endswith('\r'):
                            line = line[:-1]
                        self._log(line.rstrip())
            if buffer:
                self._log(buffer.rstrip())

            proc.wait()
            success = proc.returncode == 0

            with open(log_file, "w", encoding="utf-8") as f:
                f.write(f"任务名称: {task_name}\n")
                f.write(f"脚本: {os.path.basename(script_path)}\n")
                f.write(f"开始时间: {timestamp}\n")
                f.write(f"返回码: {proc.returncode}\n")
                f.write(f"状态: {'成功' if success else '失败'}\n")

            self._log(f"\n  [完成] {task_name} - {'成功' if success else '失败'}")
            return success

        except Exception as e:
            self._log(f"[错误] {e}")
            return False

    def _prepare_cookie_file(self, cookie):
        if cookie:
            with open(COOKIE_FILE, "w", encoding="utf-8") as f:
                f.write(cookie)
        else:
            if os.path.exists(COOKIE_FILE):
                try:
                    os.remove(COOKIE_FILE)
                except Exception:
                    pass

    def _download_single(self):
        if self.is_running:
            return
        bv = self.bv_entry.get().strip()
        if not bv:
            messagebox.showwarning("提示", "请输入BV号")
            return
        quality = self.quality_entry.get().strip()
        if not quality:
            quality = "80"
        cookie = self.cookie_text.get('1.0', tk.END).strip()

        self._set_running(True)

        def worker():
            self._prepare_cookie_file(cookie)
            inputs = [bv, "", quality]
            self._run_script_thread(SCRIPTS["bspv"], inputs, f"单视频_{bv}")
            self.root.after(0, lambda: self._set_running(False))

        threading.Thread(target=worker, daemon=True).start()

    def _download_search(self):
        if self.is_running:
            return
        keyword = self.keyword_entry.get().strip()
        if not keyword:
            messagebox.showwarning("提示", "请输入搜索关键词")
            return
        count_str = self.count_entry.get().strip()
        try:
            count = int(count_str) if count_str else 5
        except ValueError:
            count = 5
        cookie = self.cookie_text.get('1.0', tk.END).strip()

        self._set_running(True)

        def worker():
            self._prepare_cookie_file(cookie)
            inputs = [keyword, str(count)]
            if not cookie:
                inputs.append("")
            self._run_script_thread(SCRIPTS["bsps"], inputs, f"批量下载_{keyword}")
            self.root.after(0, lambda: self._set_running(False))

        threading.Thread(target=worker, daemon=True).start()

    def _download_pgc(self):
        if self.is_running:
            return
        url = self.pgc_entry.get().strip()
        if not url:
            messagebox.showwarning("提示", "请输入番剧URL")
            return
        cookie = self.cookie_text.get('1.0', tk.END).strip()

        self._set_running(True)

        def worker():
            self._prepare_cookie_file(cookie)
            inputs = [url]
            if not cookie:
                inputs.append("")
            inputs.append("1")
            inputs.append("y")
            self._run_script_thread(SCRIPTS["bsp"], inputs, "番剧下载")
            self.root.after(0, lambda: self._set_running(False))

        threading.Thread(target=worker, daemon=True).start()

    def _run_batch_tasks(self):
        if self.is_running:
            return
        if not self.batch_tasks:
            messagebox.showwarning("提示", "任务列表为空，请先添加任务")
            return

        cookie = self.cookie_text.get('1.0', tk.END).strip()

        confirm = messagebox.askyesno("确认", f"即将执行 {len(self.batch_tasks)} 个任务，是否开始？")
        if not confirm:
            return

        self._set_running(True)

        def worker():
            self._prepare_cookie_file(cookie)
            results = []
            start_time = time.time()
            total = len(self.batch_tasks)

            for i, task in enumerate(self.batch_tasks, 1):
                self._log(f"\n\n{'#'*60}")
                self._log(f"#  任务 {i}/{total}: {task['desc']}")
                self._log(f"{'#'*60}\n")

                if task["type"] == "bv":
                    quality = task.get("quality") or "80"
                    inputs = [task["bv"], "", quality]
                    ok = self._run_script_thread(
                        SCRIPTS["bspv"], inputs, f"单视频_{task['bv']}"
                    )
                elif task["type"] == "search":
                    inputs = [task["keyword"], str(task["count"])]
                    if not cookie:
                        inputs.append("")
                    ok = self._run_script_thread(
                        SCRIPTS["bsps"], inputs, f"批量下载_{task['keyword']}"
                    )
                elif task["type"] == "pgc":
                    inputs = [task["url"]]
                    if not cookie:
                        inputs.append("")
                    inputs.append("1")
                    inputs.append("y")
                    ok = self._run_script_thread(
                        SCRIPTS["bsp"], inputs, "番剧下载"
                    )
                else:
                    ok = False

                results.append({"task": task, "success": ok})

            elapsed = time.time() - start_time
            success_count = sum(1 for r in results if r["success"])

            self._log("\n" + "="*60)
            self._log("  全部任务执行完毕")
            self._log(f"  总耗时: {elapsed:.1f} 秒")
            self._log(f"  成功: {success_count}/{total}")
            self._log("="*60)
            self._log("\n任务详情:")
            for i, r in enumerate(results, 1):
                status = "✓ 成功" if r["success"] else "✗ 失败"
                self._log(f"  {i}. {status} - {r['task']['desc']}")

            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            summary_file = os.path.join(LOG_DIR, f"{timestamp}_batch_summary.txt")
            with open(summary_file, "w", encoding="utf-8") as f:
                f.write("===== 批量任务汇总 =====\n")
                f.write(f"总耗时: {elapsed:.1f} 秒\n")
                f.write(f"成功: {success_count}/{total}\n\n")
                for i, r in enumerate(results, 1):
                    f.write(f"--- 任务 {i} ---\n")
                    f.write(f"  描述: {r['task']['desc']}\n")
                    f.write(f"  状态: {'成功' if r['success'] else '失败'}\n\n")
            self._log(f"\n详细汇总已保存到: {summary_file}")

            self.root.after(0, lambda: self._set_running(False))

        threading.Thread(target=worker, daemon=True).start()


def main():
    root = tk.Tk()
    app = BilibiliDownloaderGUI(root)
    root.mainloop()


if __name__ == "__main__":
    main()
